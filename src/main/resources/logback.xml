<configuration>
    <!-- Single-line JSON-friendly format for Cloud Run structured logging -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSS'Z',UTC} %-5level %logger{30} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Silence noisy third-party libraries -->
    <logger name="io.netty"                     level="WARN"/>
    <logger name="io.grpc"                      level="WARN"/>
    <logger name="com.google"                   level="WARN"/>
    <logger name="io.ktor.server.routing"       level="WARN"/>
    <logger name="io.ktor.client"               level="WARN"/>

    <!-- Application logger: WARN in production keeps output minimal -->
    <logger name="com.diary" level="WARN"/>

    <root level="WARN">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
